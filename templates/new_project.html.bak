
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>大纲构建 - 小说创作助手</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary: #0ea5e9;
            --primary-dark: #0284c7;
            --success: #22c55e;
            --danger: #ef4444;
        }
        body {
            background: #f0f4f8;
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #d0d5dd;
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #b0b5bd;
        }
        .main-content-full {
            height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .content-header {
            border-bottom: 1px solid #e2e8f0;
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
            background: white;
        }
        .content-header h5 {
            color: #1e293b;
        }
        .btn-gradient {
            border: none;
            border-radius: 10px;
            padding: 0.5rem 1rem;
            font-weight: 600;
            font-size: 0.875rem;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            cursor: pointer;
        }
        .btn-gradient:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }
        .btn-gradient-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
        }
        .btn-gradient-primary:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(14, 165, 233, 0.3);
        }
        .btn-gradient-success {
            background: linear-gradient(135deg, var(--success) 0%, #16a34a 100%);
            color: white;
        }
        .btn-gradient-success:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
        }
        .split-view {
            flex: 1;
            display: flex;
            overflow: hidden;
        }
        .middle-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            margin: 1rem 1rem 1rem 1rem;    
            overflow: hidden;
        }
        .right-panel {
            width: 38%;
            min-width: 400px;
            display: flex;
            flex-direction: column;
            margin: 1rem 1rem 1rem 0;
            overflow: hidden;
        }
        .outline-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            flex: 1;
            transition: box-shadow 0.25s ease;
        }
        .outline-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        }
        .outline-card-header {
            padding: 0.875rem 1rem;
            background: #e2e8f0;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .outline-card-header h5 {
            margin: 0;
            font-size: 0.95rem;
            font-weight: 600;
        }
        .outline-card-body {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        #outline-content {
            flex: 1;
            width: 100%;
            border: none;
            resize: none;
            padding: 1.25rem;
            font-family: inherit;
            font-size: 0.95rem;
            line-height: 1.7;
            white-space: pre-wrap;
        }
        #outline-content:focus {
            outline: none;
        }
        #outline-content::placeholder {
            color: #94a3b8;
            font-size: 0.95rem;
        }
        /* 打字机效果光标 */
        .typing-cursor {
            display: inline-block;
            width: 2px;
            height: 1em;
            background: var(--primary);
            animation: blink 0.8s infinite;
            vertical-align: text-bottom;
            margin-left: 1px;
        }
        @keyframes blink {
            0%, 50% { opacity: 1; }
            51%, 100% { opacity: 0; }
        }
        #outline-preview {
            flex: 1;
            overflow-y: auto;
            padding: 1.25rem;
            line-height: 1.7;
        }
        .outline-empty {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: #94a3b8;
        }
        .outline-empty i {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }
        .outline-empty p {
            font-size: 0.9rem;
            margin: 0;
        }
        .chat-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            flex: 1;
            transition: box-shadow 0.25s ease;
        }
        .chat-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        }
        .chat-card-body {
            flex: 1;
            overflow-y: auto;
            padding: 0.75rem 0.875rem;
            background: #fafafa;
        }
        .chat-card-footer {
            padding: 0.75rem;
            border-top: 1px solid #e2e8f0;
            background: white;
        }
        .chat-input-wrap {
            display: flex;
            gap: 0.5rem;
            align-items: flex-end;
        }
        .chat-input-wrap textarea {
            flex: 1;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            padding: 0.625rem 0.875rem;
            font-size: 0.875rem;
            resize: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            min-height: 44px;
            max-height: 160px;
        }
        .chat-input-wrap textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
        }
        .chat-input-wrap textarea:disabled {
            background-color: #f1f5f9;
            cursor: not-allowed;
            color: #64748b;
        }
        .btn-send {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            border: none;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
            transition: all 0.2s;
            cursor: pointer;
        }
        .btn-send:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(14, 165, 233, 0.35);
        }
        .btn-send:active {
            transform: translateY(0);
        }
        .btn-send:disabled {
            background: #cbd5e1;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }
        .btn-send:disabled:hover {
            transform: none;
            box-shadow: none;
        }
        .chat-message {
            display: flex;
            margin-bottom: 0.625rem;
        }
        .chat-message.user {
            justify-content: flex-end;
        }
        .chat-message-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            font-weight: 600;
            flex-shrink: 0;
        }
        .avatar-me {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
        }
        .avatar-ai {
            background: linear-gradient(135deg, rgba(14, 165, 233, 0.12) 0%, rgba(56, 189, 248, 0.12) 100%);
            color: var(--primary);
        }
        .chat-bubble {
            max-width: 85%;
            padding: 0.875rem 1.125rem;
            border-radius: 16px;
            font-size: 0.9rem;
            line-height: 1.6;
        }
        .chat-bubble-user {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
            border-bottom-right-radius: 4px;
        }
        .chat-bubble-assistant {
            background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
            color: #334155;
            border-bottom-left-radius: 4px;
        }
        .btn-group-toggle .btn {
            border-radius: 6px;
            padding: 0.2rem 0.6rem;
            font-size: 0.75rem;
            border: 1px solid #e2e8f0;
            background: white;
            color: #64748b;
            transition: all 0.2s;
            line-height: 1.2;
        }
        .btn-group-toggle .btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }
        .btn-group-toggle .btn:not(.active):hover {
            border-color: var(--primary);
            color: var(--primary);
        }
        .badge-secondary {
            background: linear-gradient(135deg, rgba(100, 116, 139, 0.12) 0%, rgba(148, 163, 184, 0.12) 100%);
            color: #64748b;
            border: none;
        }
        /* Modal Styles */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.show {
            display: flex;
        }
        .modal-content {
            background: white;
            border-radius: 20px;
            width: 90%;
            max-width: 560px;
            overflow: hidden;
            animation: modalFadeIn 0.3s ease;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
        }
        @keyframes modalFadeIn {
            from { opacity: 0; transform: translateY(-20px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        .modal-header {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        }
        .modal-header h5 {
            margin: 0;
            font-size: 1.125rem;
            font-weight: 700;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 0.625rem;
        }
        .modal-header h5 i {
            color: var(--primary);
            font-size: 1rem;
        }
        .modal-header .btn-close {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #e2e8f0;
            border: none;
            color: #64748b;
            transition: all 0.2s;
        }
        .modal-header .btn-close:hover {
            background: #cbd5e1;
            color: #475569;
            transform: rotate(90deg);
        }
        .modal-body {
            padding: 1rem 1.5rem 0rem;
        }
        .modal-body .form-label {
            font-weight: 600;
            color: #334155;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }
        .modal-body .form-control {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 0.75rem 1rem;
            font-size: 0.9rem;
            transition: all 0.2s;
        }
        .modal-body .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.15);
        }
        .modal-footer {
            padding: 1.25rem 1.5rem;
            border-top: 1px solid #f1f5f9;
            display: flex;
            justify-content: flex-end;
            gap: 0.75rem;
            background: #f8fafc;
        }
        .modal-footer .btn {
            padding: 0.625rem 1.5rem;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.2s;
        }
        .modal-footer .btn-secondary {
            background: #e2e8f0;
            border: none;
            color: #475569;
        }
        .modal-footer .btn-secondary:hover {
            background: #cbd5e1;
            transform: translateY(-1px);
        }
        /* AI Button Styles */
        .ai-generate-btn {
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            border: none;
            color: white;
            border-radius: 8px;
            padding: 0.4rem 0.6rem;
            font-weight: 600;
            font-size: 0.8rem;
            display: inline-flex;
            align-items: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);
            cursor: pointer;
            min-width: 75px;
            justify-content: center;
        }
        .ai-generate-btn:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 6px 20px rgba(99, 102, 241, 0.45);
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        }
        .ai-generate-btn:active {
            transform: translateY(0) scale(0.96);
            box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);
            animation: clickPulse 0.2s ease-out;
        }
        @keyframes clickPulse {
            0% {
                box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.5);
            }
            100% {
                box-shadow: 0 0 0 12px rgba(99, 102, 241, 0);
            }
        }
        .ai-generate-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            box-shadow: none;
        }
        .ai-generate-btn:not(:disabled) i {
            font-size: 0.8rem;
            animation: sparkle 1.5s ease-in-out infinite;
        }
        @keyframes sparkle {
            0%, 100% {
                filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.5));
            }
            50% {
                filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.8));
            }
        }
        .suggestion-tip {
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            color: #6366f1;
            font-weight: 500;
            font-size: 0.8rem;
            margin-bottom: 0.75rem;
            padding: 0.5rem;
            background: rgba(99, 102, 241, 0.1);
            border-radius: 8px;
            border-left: 3px solid #6366f1;
        }
        .suggestion-tip i {
            animation: bounce 1s ease-in-out infinite;
        }
        @keyframes bounce {
            0%, 100% {
                transform: translateX(0);
            }
            50% {
                transform: translateX(3px);
            }
        }
        .input-group {
            border-radius: 12px;
            overflow: hidden;
        }
        .input-group .form-control {
            border-top-right-radius: 0;
            border-bottom-right-radius: 0;
        }
        .input-group .ai-generate-btn {
            border-top-left-radius: 0;
            border-bottom-left-radius: 0;
            box-shadow: none;
        }
        /* Toast */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 2000;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .toast-item {
            background: white;
            color: #1e293b;
            padding: 0.875rem 1.25rem;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            box-shadow: 0 8px 32px rgba(0,0,0,0.15);
            animation: toastSlideIn 0.3s ease;
            font-size: 0.9rem;
            font-weight: 500;
            min-width: 280px;
        }
        .toast-item.toast-success {
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            color: white;
        }
        .toast-item.toast-error {
            background: linear-gradient(135deg, var(--danger) 0%, #dc2626 100%);
            color: white;
        }
        @keyframes toastSlideIn {
            from { opacity: 0; transform: translateX(100%); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes toastSlideOut {
            from { opacity: 1; transform: translateX(0); }
            to { opacity: 0; transform: translateX(100%); }
        }
        /* 加载动画 - 三点跳动 */
        .typing-dots::after {
            content: '';
            animation: typingDots 1.5s infinite;
        }
        @keyframes typingDots {
            0% { content: ''; }
            25% { content: '.'; }
            50% { content: '..'; }
            75% { content: '...'; }
            100% { content: ''; }
        }
        .typing-dots {
            display: inline-block;
        }
        /* 打字指示器动画 */
        .typing-indicator {
            display: inline-flex;
            gap: 4px;
            margin-right: 4px;
        }
        .typing-indicator i {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background-color: var(--primary);
            animation: typingPulse 1.4s ease-in-out infinite;
            font-size: 0;
        }
        .typing-indicator i:nth-child(1) { animation-delay: 0s; }
        .typing-indicator i:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator i:nth-child(3) { animation-delay: 0.4s; }
        @keyframes typingPulse {
            0%, 80%, 100% {
                opacity: 0.3;
                transform: scale(0.8);
            }
            40% {
                opacity: 1;
                transform: scale(1);
            }
        }
        /* AI Generate Button */
        .input-group .btn-outline-secondary {
            background: #f8fafc;
            border-color: var(--primary);
            color: var(--primary);
        }
        /* Title Suggestions */
        .title-suggestions {
            margin-top: 0.75rem;
            background: linear-gradient(135deg, rgba(14, 165, 233, 0.08) 0%, rgba(56, 189, 248, 0.08) 100%);
            border: 1px solid rgba(14, 165, 233, 0.2);
            border-radius: 12px;
            overflow: hidden;
        }
        .title-suggestions-header {
            padding: 0.625rem 0.875rem;
            background: rgba(14, 165, 233, 0.1);
            font-weight: 600;
            font-size: 0.8rem;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 0.375rem;
        }
        .title-suggestions-list {
            padding: 0.5rem;
        }
        .title-suggestion-item {
            padding: 0.5rem 0.75rem;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.875rem;
        }
        .title-suggestion-item:hover {
            background: rgba(14, 165, 233, 0.1);
        }
        /* Description suggestions */
        .description-suggestions {
            margin-top: 0.75rem;
            background: linear-gradient(135deg, rgba(34, 197, 94, 0.08) 0%, rgba(22, 163, 74, 0.08) 100%);
            border: 1px solid rgba(34, 197, 94, 0.2);
            border-radius: 12px;
            overflow: hidden;
        }
        .description-suggestions-header {
            padding: 0.625rem 0.875rem;
            background: rgba(34, 197, 94, 0.1);
            font-weight: 600;
            font-size: 0.8rem;
            color: var(--success);
            display: flex;
            align-items: center;
            gap: 0.375rem;
        }
        .description-suggestion-content {
            padding: 0.75rem;
            font-size: 0.875rem;
            line-height: 1.6;
            cursor: pointer;
            transition: all 0.2s;
            border-radius: 8px;
        }
        .description-suggestion-content:hover {
            background: rgba(34, 197, 94, 0.1);
        }
        /* 聊天消息操作按钮 */
        .chat-message {
            display: flex;
            margin-bottom: 0.625rem;
            align-items: flex-start;
        }
        .chat-message.user {
            justify-content: flex-end;
        }
        .chat-message-content {
            display: flex;
            align-items: flex-start;
            flex: 1;
        }
        .chat-message.user .chat-message-content {
            flex-direction: row-reverse;
        }
        .chat-message-actions {
            display: none;
            padding: 0 0.5rem;
            align-items: center;
        }
        .chat-message:hover .chat-message-actions {
            display: flex;
        }
        .chat-message-checkbox {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }
        /* 头部操作按钮 */
        .outline-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .header-actions {
            display: flex;
            gap: 0.5rem;
        }
        /* 多选工具栏 */
        .multi-select-toolbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem 0.75rem;
            background: #f0f9ff;
            border-bottom: 1px solid #e2e8f0;
        }
        .multi-select-toolbar span {
            flex: 1;
            font-size: 0.875rem;
            color: #64748b;
        }
    </style>
</head>
<body>
    <div class="main-content-full">
        <div class="content-header">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-outline-secondary" onclick="goBack()">
                    <i class="fas fa-arrow-left"></i>
                </button>
                <div>
                    <h5 class="mb-0">大纲构建</h5>
                    <small class="text-muted">通过AI对话构建小说大纲</small>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-gradient-success" onclick="openSaveModal()" id="save-btn" disabled>
                    <i class="fas fa-save"></i> 保存项目
                </button>
            </div>
        </div>

        <div class="split-view">
            <div class="middle-panel">
                <div class="outline-card">
                    <div class="outline-card-header">
                        <div class="d-flex align-items-center gap-2">
                            <h5><i class="fas fa-edit me-2"></i>大纲内容</h5>
                        </div>
                        <div class="btn-group-toggle d-flex gap-1">
                            <button class="btn" id="btn-edit" onclick="showEditMode()">编辑</button>
                            <button class="btn active" id="btn-preview" onclick="showPreviewMode()">预览</button>
                        </div>
                    </div>
                    <div class="outline-card-body">
                        <textarea id="outline-content" class="d-none" placeholder="通过左侧AI对话逐步构建您的小说大纲...&#10;&#10;例如：&#10;- 我想写一个修仙小说&#10;- 主角是个废柴逆袭&#10;- 有个系统帮助修炼"></textarea>
                        <div id="outline-preview">
                            <div class="outline-empty">
                                <i class="fas fa-file-text"></i>
                                <p>通过AI对话逐步构建小说大纲</p>
                                <p class="mt-2" style="font-size: 0.8rem;">试试发送："我想写一个修仙小说"</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="right-panel">
                <div class="chat-card">
                    <div class="outline-card-header">
                        <h5><i class="fas fa-robot me-2"></i>AI大纲助手</h5>
                        <div class="header-actions">
                            <button class="btn btn-sm btn-outline-secondary" onclick="toggleMultiSelectMode()" title="多选删除">
                                <i class="fas fa-check-square"></i>
                            </button>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" title="设置">
                                    <i class="fas fa-cog"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <div class="dropdown-item">
                                            <label class="form-label mb-1 small">历史消息数量</label>
                                            <select class="form-select form-select-sm" id="history-count-select" onchange="historyCount = parseInt(this.value); localStorage.setItem('outline_history_count', historyCount);">
                                                <option value="5">5 条</option>
                                                <option value="10" selected>10 条</option>
                                                <option value="15">15 条</option>
                                                <option value="20">20 条</option>
                                                <option value="0">全部</option>
                                            </select>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div id="multi-select-toolbar" class="multi-select-toolbar" style="display: none;">
                        <span id="selected-count">已选择 0 条</span>
                        <button class="btn btn-sm btn-danger" onclick="deleteSelectedMessages()">
                            <i class="fas fa-trash"></i> 删除
                        </button>
                        <button class="btn btn-sm btn-secondary" onclick="toggleMultiSelectMode()">取消</button>
                    </div>
                    <div class="chat-card-body" id="chat-messages">
                        <div class="chat-message assistant">
                            <div class="chat-message-avatar avatar-ai me-2">AI</div>
                            <div class="chat-bubble chat-bubble-assistant">
                                您好！我是您的小说大纲助手，可以帮助您从零开始构建完整的小说大纲。<br><br>
                                请告诉我您想创作什么样的小说？例如：<br>
                                例如:"我想写一个都市异能小说"<br>
                                例如:"帮我构思一个修仙世界的故事"<br>
                                例如:"我想写一个穿越到古代的言情故事"<br><br>
                                我会通过提问引导您完善大纲的各个要素。
                            </div>
                        </div>
                    </div>
                    <div class="chat-card-footer">
                        <div class="chat-input-wrap">
                            <textarea id="chat-input" rows="3" placeholder="输入您的小说想法...（Shift+Enter 换行，Enter 发送）"></textarea>
                            <button class="btn-send" id="send-message">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 保存项目弹窗 -->
    <div class="modal-overlay" id="save-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h5><i class="fas fa-save me-2"></i>保存项目</h5>
                <button class="btn btn-close" onclick="closeSaveModal()"></button>
            </div>
            <div class="modal-body">
                <form id="save-form">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label mb-0">小说名称</label>
                            <button type="button" class="ai-generate-btn" id="ai-generate-title-btn" onclick="generateTitle()">
                                <i class="fas fa-sparkles"></i> AI生成
                            </button>
                        </div>
                        <input type="text" class="form-control" id="project-title" placeholder="输入小说名称" required>
                        <div id="title-suggestions-container" style="display: none;">
                            <div class="title-suggestions">
                                <div class="title-suggestions-header">
                                    <i class="fas fa-lightbulb"></i>
                                    AI推荐的书名
                                </div>
                                <div class="title-suggestions-list" id="title-suggestions-list"></div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label mb-0">小说简介</label>
                            <button type="button" class="ai-generate-btn" id="ai-generate-desc-btn" onclick="generateDescription()">
                                <i class="fas fa-sparkles"></i> AI生成
                            </button>
                        </div>
                        <textarea class="form-control" id="project-description" rows="4" placeholder="输入小说简介"></textarea>
                        <div id="description-suggestions-container" style="display: none; margin-top: 0.75rem;">
                            <div class="description-suggestions">
                                <div class="description-suggestions-header">
                                    <i class="fas fa-lightbulb"></i>
                                    AI推荐的简介
                                </div>
                                <div class="description-suggestion-content" id="description-suggestion-content"></div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeSaveModal()">
                    <i class="fas fa-times me-1"></i> 取消
                </button>
                <button class="btn btn-gradient-success" onclick="saveProject()" id="confirm-save-btn">
                    <i class="fas fa-check me-1"></i> 确认保存
                </button>
            </div>
        </div>
    </div>

    <div class="toast-container" id="toast-container"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="/static/js/common.js"></script>
    <script>
        let messages = [];
        let currentOutline = '';
        let isTyping = false;
        let currentTypingTimeout = null;
        let pendingQuestion = '';
        let collectedAIResponse = '';
        let currentProjectId = null;  // 当前项目 ID
        let autoSaveTimer = null;     // 已禁用
        let lastSavedContent = '';    // 已禁用
        let isMultiSelectMode = false;  // 多选模式
        let historyCount = 10;          // 传给后端的历史消息数量
        document.addEventListener('DOMContentLoaded', function() {
            checkAuth();

            // 从 localStorage 加载历史消息数量设置
            const savedHistoryCount = localStorage.getItem('outline_history_count');
            if (savedHistoryCount !== null) {
                historyCount = parseInt(savedHistoryCount);
                const select = document.getElementById('history-count-select');
                if (select) select.value = historyCount;
            }

            // 检查是否有项目 ID 参数
            const urlParams = new URLSearchParams(window.location.search);
            const projectIdFromUrl = urlParams.get('project_id');
            if (projectIdFromUrl) {
                loadExistingProject(projectIdFromUrl);
            }

            document.getElementById('outline-content').addEventListener('input', function() {
                updateButtons();
            });

            document.getElementById('send-message').addEventListener('click', sendMessage);
            document.getElementById('chat-input').addEventListener('keydown', function(e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });

            const chatInput = document.getElementById('chat-input');
            chatInput.addEventListener('input', function() {
                this.style.height = 'auto';
                this.style.height = Math.min(this.scrollHeight, 160) + 'px';
            });
        });

        async function checkAuth() {
            if (!api.isAuthenticated()) {
                window.location.href = 'login.html';
                return;
            }
            try {
                const data = await api.get('/api/auth/user/');
                if (!data.success) {
                    api.logout();
                }
            } catch (error) {
                api.logout();
            }
        }

        // 加载已有项目数据
        async function loadExistingProject(projectId) {
            try {
                // 获取项目基本信息
                const projectData = await api.get(`/api/projects/${projectId}/`);
                if (projectData.success) {
                    currentProjectId = projectId;
                    document.getElementById('project-title').value = projectData.project.title || '';
                    document.getElementById('project-description').value = projectData.project.description || '';
                }

                // 获取最新的大纲版本和聊天记录
                const outlineData = await api.get(`/api/projects/${projectId}/outline/latest/`);
                console.log('API返回的大纲数据', JSON.stringify(outlineData));
                if (outlineData.success && outlineData.outline) {
                    currentOutline = outlineData.outline.content || '';
                    document.getElementById('outline-content').value = currentOutline;

                    // 根据是否有内容切换显示模式
                    if (currentOutline.trim()) {
                        document.getElementById('outline-preview').innerHTML = marked.parse(currentOutline);
                        showPreviewMode();
                    } else {
                        showEditMode();
                    }

                    // 加载聊天记录
                    if (outlineData.messages && outlineData.messages.length > 0) {
                        messages = outlineData.messages.map(msg => ({
                            id: msg.id,
                            role: msg.role,
                            content: msg.content
                        }));
                        // 渲染聊天历史
                        renderChatHistory();
                    }

                    updateButtons();
                }
            } catch (error) {
                console.error('加载项目失败:', error);
            }
        }

        // 渲染聊天历史
        function renderChatHistory() {
            const chatMessages = document.getElementById('chat-messages');
            chatMessages.innerHTML = '';
            console.log('渲染聊天历史, messages:', JSON.stringify(messages));
            messages.forEach((msg, index) => {
                const div = document.createElement('div');
                div.className = `chat-message ${msg.role}`;
                div.dataset.index = index;
                div.dataset.id = msg.id || '';

                let checkboxHtml = `<input type="checkbox" class="chat-message-checkbox" data-index="${index}" style="display: ${isMultiSelectMode ? 'inline-block' : 'none'}" onclick="updateSelectedCount()">`;

                if (msg.role === 'user') {
                    div.innerHTML = `
                        ${checkboxHtml}
                        <div class="chat-message-content">
                            <div class="chat-bubble chat-bubble-user">${escapeHtml(msg.content).replace(/\n/g, '<br>')}</div>
                            <div class="chat-message-avatar avatar-me ms-2">我</div>
                        </div>
                    `;
                } else {
                    // assistant 或其他角色（比如system）
                    const content = msg.content || '';
                    console.log('渲染AI消息, role:', msg.role, 'content长度:', content.length);
                    if (content) {
                        div.innerHTML = `
                            ${checkboxHtml}
                            <div class="chat-message-content">
                                <div class="chat-message-avatar avatar-ai me-2">AI</div>
                                <div class="chat-bubble chat-bubble-assistant">${escapeHtml(content).replace(/\n/g, '<br>')}</div>
                            </div>
                        `;
                    } else {
                        div.innerHTML = `
                            ${checkboxHtml}
                            <div class="chat-message-content">
                                <div class="chat-message-avatar avatar-ai me-2">AI</div>
                                <div class="chat-bubble chat-bubble-assistant"><em>(空回复)</em></div>
                            </div>
                        `;
                    }
                }
                chatMessages.appendChild(div);
            });
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        // 更新选中数量显示
        function updateSelectedCount() {
            const checked = document.querySelectorAll('.chat-message-checkbox:checked').length;
            const countSpan = document.getElementById('selected-count');
            if (countSpan) countSpan.textContent = `已选择 ${checked} 条`;
        }
        
        // 删除选中消息
        async function deleteSelectedMessages() {
            const selectedIds = [];
            const selectedIndexes = [];
            
            document.querySelectorAll('.chat-message-checkbox:checked').forEach(cb => {
                const index = parseInt(cb.dataset.index);
                if (messages[index] && messages[index].id) {
                    selectedIds.push(messages[index].id);
                    selectedIndexes.push(index);
                }
            });
            
            if (selectedIds.length === 0) {
                showToast('请选择要删除的消息', 'warning');
                return;
            }
            
            if (!confirm(`确定删除选中的 ${selectedIds.length} 条消息？`)) return;
            
            try {
                const data = await api.post('/api/chat-history/delete/', {
                    project_id: currentProjectId,
                    message_ids: selectedIds
                });
                
                if (data.success) {
                    // 按索引倒序删除
                    selectedIndexes.sort((a, b) => b - a).forEach(i => messages.splice(i, 1));
                    renderChatHistory();
                    toggleMultiSelectMode();
                    showToast(`已删除 ${data.deleted_count} 条消息`);
                } else {
                    showToast('删除失败: ' + data.message, 'danger');
                }
            } catch (error) {
                console.error('批量删除失败:', error);
                showToast('删除失败', 'danger');
            }
        }
        
        // 切换多选模式
        function toggleMultiSelectMode() {
            isMultiSelectMode = !isMultiSelectMode;
            const checkboxes = document.querySelectorAll('.chat-message-checkbox');
            const toolbar = document.getElementById('multi-select-toolbar');

            checkboxes.forEach(cb => cb.style.display = isMultiSelectMode ? 'inline-block' : 'none');
            if (toolbar) toolbar.style.display = isMultiSelectMode ? 'flex' : 'none';

            // 更新复选框状态
            document.querySelectorAll('.chat-message').forEach(div => {
                const checkbox = div.querySelector('.chat-message-checkbox');
                if (checkbox) checkbox.checked = false;
            });

            // 更新选中数量
            updateSelectedCount();
        }

        function updateButtons() {
            const content = document.getElementById('outline-content').value;
            document.getElementById('save-btn').disabled = content.trim() === '';
        }

        function showEditMode() {
            document.getElementById('outline-content').classList.remove('d-none');
            document.getElementById('outline-preview').classList.add('d-none');
            document.getElementById('btn-edit').classList.add('active');
            document.getElementById('btn-preview').classList.remove('active');
        }

        function showPreviewMode() {
            const content = document.getElementById('outline-content').value;
            if (content.trim()) {
                document.getElementById('outline-preview').innerHTML = marked.parse(content);
            }
            document.getElementById('outline-content').classList.add('d-none');
            document.getElementById('outline-preview').classList.remove('d-none');
            document.getElementById('btn-preview').classList.add('active');
            document.getElementById('btn-edit').classList.remove('active');
        }

        // 打字机效果函数
        function typeWriter(element, text, callback) {
            isTyping = true;
            let index = 0;
            element.value = '';
            element.classList.remove('d-none');
            document.getElementById('outline-preview').classList.add('d-none');
            document.getElementById('btn-edit').classList.add('active');
            document.getElementById('btn-preview').classList.remove('active');

            function type() {
                if (!isTyping) return;
                if (index < text.length) {
                    element.value += text.charAt(index);
                    index++;
                    currentTypingTimeout = setTimeout(type, 15);
                } else {
                    isTyping = false;
                    currentTypingTimeout = null;
                    if (callback) callback();
                }
            }
            type();
        }

        function stopTyping() {
            isTyping = false;
            if (currentTypingTimeout) {
                clearTimeout(currentTypingTimeout);
                currentTypingTimeout = null;
            }
        }

        async function sendMessage() {
            const input = document.getElementById('chat-input');
            const message = input.value.trim();
            if (!message) return;

            input.disabled = true;
            document.getElementById('send-message').disabled = true;

            const chatMessages = document.getElementById('chat-messages');
            const userDiv = document.createElement('div');
            userDiv.className = 'chat-message user';
            userDiv.innerHTML = `
                <div class="chat-bubble chat-bubble-user">${escapeHtml(message).replace(/\n/g, '<br>')}</div>
                <div class="chat-message-avatar avatar-me ms-2">我</div>
            `;
            chatMessages.appendChild(userDiv);

            // 创建"思考中"状态 - 在聊天区域
            const thinkingDiv = document.createElement('div');
            thinkingDiv.className = 'chat-message assistant';
            thinkingDiv.innerHTML = `
                <div class="chat-message-avatar avatar-ai me-2">AI</div>
                <div class="chat-bubble chat-bubble-assistant">
                    <i class="fas fa-spinner fa-spin"></i> 思考中...
                </div>
            `;
            chatMessages.appendChild(thinkingDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;

            messages.push({ role: 'user', content: message });
            input.value = '';
            input.style.height = 'auto';

            collectedAIResponse = '';
            pendingQuestion = '';

            // 根据 historyCount 限制发送给后端的消息数量
            const messagesToSend = historyCount > 0 ? messages.slice(-historyCount) : messages;

            try {
                const response = await fetch('/api/chat/new-outline/', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${api.getToken()}`,
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: `message=${encodeURIComponent(message)}&current_outline=${encodeURIComponent(currentOutline)}&messages=${encodeURIComponent(JSON.stringify(messagesToSend))}&project_id=${currentProjectId || ''}`
                });

                const reader = response.body.getReader();
                const decoder = new TextDecoder();

                // 分隔符（使用ASCII等号避免Unicode处理问题）
                const CONTENT_START = '════CONTENT_START════';
                const CONTENT_END = '════CONTENT_END════';
                const QUESTION_START = '════QUESTION_START════';
                const QUESTION_END = '════QUESTION_END════';

                let rawTextBuffer = '';  // 原始文本流缓冲区
                let isComplete = false;
                let parsedOutline = '';
                let parsedQuestion = '';

                // 流式打印状态
                let inOutlineSection = false;
                let inQuestionSection = false;
                let currentOutlineText = '';
                let currentQuestionText = '';
                let chatTypingDiv = null;

                // 初始化聊天打字区域
                function initChatTyping() {
                    chatTypingDiv = document.createElement('div');
                    chatTypingDiv.className = 'chat-bubble chat-bubble-assistant';
                    // 初始显示"输出中..."状态，带有动画效果
                    chatTypingDiv.innerHTML = '<span class="typing-indicator"><i class="fas fa-circle"></i><i class="fas fa-circle"></i><i class="fas fa-circle"></i></span> 输出中...';
                    thinkingDiv.innerHTML = `<div class="chat-message-avatar avatar-ai me-2">AI</div>`;
                    thinkingDiv.appendChild(chatTypingDiv);
                }

                // 流式打印到聊天区域
                function streamToChat(text) {
                    if (!chatTypingDiv) return;
                    chatTypingDiv.innerHTML = escapeHtml(text).replace(/\n/g, '<br>');
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }

                // 检测并处理流式内容
                function processStream(buffer) {
                    // 检测所有分隔符位置
                    const csIdx = buffer.indexOf(CONTENT_START);
                    const ceIdx = buffer.indexOf(CONTENT_END);
                    const qsIdx = buffer.indexOf(QUESTION_START);
                    const qeIdx = buffer.indexOf(QUESTION_END);

                    // 确定 CONTENT 区域（大纲内容）
                    if (csIdx !== -1) {
                        const contentStartIdx = csIdx + CONTENT_START.length;
                        if (ceIdx !== -1 && ceIdx > csIdx) {
                            // CONTENT 已完成
                            currentOutlineText = buffer.substring(contentStartIdx, ceIdx);
                            inOutlineSection = false;
                            parsedOutline = currentOutlineText.trim();
                            currentOutline = parsedOutline;

                            // 完成时：更新预览区，切换到预览模式
                            const previewArea = document.getElementById('outline-preview');
                            previewArea.innerHTML = marked.parse(parsedOutline);
                            previewArea.classList.remove('d-none');
                            document.getElementById('outline-content').classList.add('d-none');
                            document.getElementById('outline-content').value = parsedOutline;
                            document.getElementById('btn-edit').classList.remove('active');
                            document.getElementById('btn-preview').classList.add('active');
                        } else if (qsIdx === -1 || qsIdx >= csIdx) {
                            // CONTENT 进行中（没有 QUESTION_START 或在它后面）
                            // 流式时：切换到编辑模式，显示原始文本
                            inOutlineSection = true;
                            currentOutlineText = buffer.substring(contentStartIdx);

                            // 切换到编辑模式
                            document.getElementById('outline-content').classList.remove('d-none');
                            document.getElementById('outline-preview').classList.add('d-none');
                            document.getElementById('outline-content').value = currentOutlineText;
                            document.getElementById('btn-edit').classList.add('active');
                            document.getElementById('btn-preview').classList.remove('active');
                        }
                    }

                    // 确定 QUESTION 区域
                    if (qsIdx !== -1) {
                        const qStartIdx = qsIdx + QUESTION_START.length;
                        inOutlineSection = false; // 切换到 QUESTION

                        if (qeIdx !== -1 && qeIdx > qsIdx) {
                            // QUESTION 已完成
                            currentQuestionText = buffer.substring(qStartIdx, qeIdx);
                            inQuestionSection = false;
                            parsedQuestion = currentQuestionText.trim();
                            pendingQuestion = parsedQuestion;
                        } else if (!inQuestionSection) {
                            // QUESTION 首次找到，开始处理
                            inQuestionSection = true;
                            currentQuestionText = buffer.substring(qStartIdx);
                        } else {
                            // QUESTION 进行中，追加新增内容
                            const currentLen = currentQuestionText.length;
                            const newLen = buffer.length - qStartIdx;
                            if (newLen > currentLen) {
                                currentQuestionText = buffer.substring(qStartIdx);
                            }
                        }
                    }

                    if (inQuestionSection && currentQuestionText) {
                        // 聊天区实时打印
                        streamToChat(currentQuestionText);
                    }
                }

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;

                    const chunk = decoder.decode(value);
                    const lines = chunk.split('\n');

                    for (const line of lines) {
                        if (line.startsWith('data: ')) {
                            try {
                                const data = JSON.parse(line.slice(6));

                                if (data.type === 'chunk') {
                                    // LLM 原始流式输出
                                    rawTextBuffer += data.data || '';

                                    // 首次收到chunk时初始化聊天打字区域
                                    if (!chatTypingDiv) {
                                        initChatTyping();
                                    }

                                    // 处理流式内容
                                    processStream(rawTextBuffer);
                                } else if (data.type === 'stream_complete') {
                                    // 流式结束
                                    isComplete = true;
                                } else if (data.type === 'complete') {
                                    // 完整响应结束
                                    isComplete = true;
                                    // 更新项目ID（重要：用于后续消息发送和页面刷新后恢复）
                                    if (data.project_id) {
                                        currentProjectId = data.project_id;
                                        console.log('收到 project_id:', currentProjectId);
                                        // 更新浏览器 URL，这样刷新页面后可以恢复项目
                                        const newUrl = new URL(window.location.href);
                                        newUrl.searchParams.set('project_id', currentProjectId);
                                        window.history.replaceState({}, '', newUrl.toString());
                                    }
                                    // 注意：后端不再返回 outline 和 question，它们已通过流式传输完成

                                    // 最终更新
                                    if (parsedOutline) {
                                        currentOutline = parsedOutline;
                                        const previewArea = document.getElementById('outline-preview');
                                        previewArea.innerHTML = marked.parse(parsedOutline);
                                        document.getElementById('outline-content').value = parsedOutline;
                                    }
                                } else if (data.type === 'outline') {
                                    // 后端解析完成的大纲内容
                                    parsedOutline = data.data || '';
                                    currentOutline = parsedOutline;
                                    const previewArea = document.getElementById('outline-preview');
                                    previewArea.innerHTML = marked.parse(parsedOutline);
                                    previewArea.classList.remove('d-none');
                                    document.getElementById('outline-content').classList.add('d-none');
                                    document.getElementById('outline-content').value = parsedOutline;
                                    document.getElementById('btn-edit').classList.remove('active');
                                    document.getElementById('btn-preview').classList.add('active');
                                } else if (data.type === 'question') {
                                    // 后端解析完成的问题内容
                                    parsedQuestion = data.data || '';
                                    pendingQuestion = parsedQuestion;

                                    // 在聊天区显示问题
                                    const questionDiv = document.createElement('div');
                                    questionDiv.className = 'chat-message assistant';
                                    questionDiv.innerHTML = `
                                        <div class="chat-message-avatar avatar-ai me-2">AI</div>
                                        <div class="chat-bubble chat-bubble-assistant">${escapeHtml(parsedQuestion).replace(/\n/g, '<br>')}</div>
                                    `;
                                    chatMessages.insertBefore(questionDiv, thinkingDiv);
                                    chatMessages.scrollTop = chatMessages.scrollHeight;
                                } else if (data.type === 'error') {
                                    thinkingDiv.innerHTML = `
                                        <div class="chat-message-avatar avatar-ai me-2">AI</div>
                                        <div class="chat-bubble chat-bubble-assistant">
                                            <i class="fas fa-exclamation-circle text-danger"></i> ${escapeHtml(data.message || '发生错误')}
                                        </div>
                                    `;
                                    chatMessages.scrollTop = chatMessages.scrollHeight;
                                }
                            } catch (e) {
                                // JSON 解析失败，忽略
                            }
                        }
                    }
                }

                // 完成后的最终处理
                if (isComplete) {
                    // 确保预览区有内容
                    if (parsedOutline && !currentOutline) {
                        currentOutline = parsedOutline;
                        document.getElementById('outline-content').value = parsedOutline;
                    }

                    // 预览区：完成时切换到预览模式
                    if (parsedOutline) {
                        const previewArea = document.getElementById('outline-preview');
                        previewArea.innerHTML = marked.parse(parsedOutline);
                        previewArea.classList.remove('d-none');
                        document.getElementById('outline-content').classList.add('d-none');
                        document.getElementById('outline-content').value = parsedOutline;
                        document.getElementById('btn-edit').classList.remove('active');
                        document.getElementById('btn-preview').classList.add('active');
                    }

                    // 聊天区：必须将内容转换为正式消息再移除 thinkingDiv
                    if (parsedQuestion) {
                        // 创建新的正式消息气泡
                        const questionDiv = document.createElement('div');
                        questionDiv.className = 'chat-message assistant';
                        questionDiv.innerHTML = `
                            <div class="chat-message-avatar avatar-ai me-2">AI</div>
                            <div class="chat-bubble chat-bubble-assistant">${escapeHtml(parsedQuestion).replace(/\n/g, '<br>')}</div>
                        `;
                        // 在 thinkingDiv 前插入新消息
                        chatMessages.insertBefore(questionDiv, thinkingDiv);
                        // 移除 thinkingDiv
                        thinkingDiv.remove();
                        messages.push({ role: 'assistant', content: parsedQuestion });
                    } else if (parsedOutline) {
                        chatTypingDiv.innerHTML = escapeHtml('大纲已生成，请查看左侧预览区').replace(/\n/g, '<br>');
                        // 移除 thinkingDiv 变为正式消息
                        thinkingDiv.remove();
                        messages.push({ role: 'assistant', content: '大纲已生成' });
                    } else {
                        thinkingDiv.remove();
                    }
                } else {
                    chatTypingDiv.innerHTML = `<i class="fas fa-exclamation-circle"></i> 抱歉，生成失败，请重试。`;
                }

                // 更新 currentProjectId（后端新创建的项目 ID）
                // 从响应体中获取 project_id
                if (parsedOutline || parsedQuestion) {
                    // 在 complete 类型的响应中已通过 data.project_id 更新
                    console.log('currentProjectId:', currentProjectId);
                }

                // 启用输入框
                input.disabled = false;
                document.getElementById('send-message').disabled = false;
                chatMessages.scrollTop = chatMessages.scrollHeight;

                // 移除 thinkingDiv
                if (thinkingDiv && thinkingDiv.parentNode) {
                    thinkingDiv.remove();
                }

            } catch (error) {
                console.error('Error:', error);
                thinkingDiv.innerHTML = `
                    <div class="chat-message-avatar avatar-ai me-2">AI</div>
                    <div class="chat-bubble chat-bubble-assistant" style="color: var(--danger);">
                        <i class="fas fa-exclamation-circle"></i> 抱歉，发生了错误，请重试。
                    </div>
                `;
                chatMessages.scrollTop = chatMessages.scrollHeight;
                // 启用输入框
                input.disabled = false;
                document.getElementById('send-message').disabled = false;
            }
        }

        function displayQuestion(question, messageDiv) {
            const chatMessages = document.getElementById('chat-messages');
            const chatInput = document.getElementById('chat-input');

            // 清除消息内容，重新创建结构
            messageDiv.innerHTML = `
                <div class="chat-message-avatar avatar-ai me-2">AI</div>
                <div class="chat-bubble chat-bubble-assistant"></div>
            `;

            // 获取 bubble
            const bubbleDiv = messageDiv.querySelector('.chat-bubble');

            // 打字机效果显示问题（使用 innerHTML 以支持换行）
            let index = 0;
            let currentHtml = '';
            const typeQuestion = () => {
                if (index < question.length) {
                    currentHtml += question.charAt(index);
                    bubbleDiv.innerHTML = escapeHtml(currentHtml).replace(/\n/g, '<br>');
                    index++;
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                    setTimeout(typeQuestion, 30);
                } else {
                    // 完成，启用输入框，触发自动保存
                    chatInput.disabled = false;
                    document.getElementById('send-message').disabled = false;
                    scheduleAutoSave();
                }
            };
            typeQuestion();

            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        // ============ 自动保存功能已禁用，聊天记录和大纲由后端保存 ============
        // async function autoSaveChat() {
        //     const content = document.getElementById('outline-content').value;
        //     if (content === lastSavedContent && currentProjectId) {
        //         return;
        //     }
        //     try {
        //         console.log('自动保存, messages数量:', messages.length);
        //         console.log('自动保存, messages内容:', JSON.stringify(messages));
        //         const response = await fetch('/api/projects/autosave/', {
        //             method: 'POST',
        //             headers: {
        //                 'Content-Type': 'application/x-www-form-urlencoded',
        //                 'X-CSRFToken': getCookie('csrftoken')
        //             },
        //             body: `project_id=${currentProjectId || ''}&outline=${encodeURIComponent(content)}&messages=${encodeURIComponent(JSON.stringify(messages))}`
        //         });
        //         const data = await response.json();
        //         if (data.success) {
        //             currentProjectId = data.project_id;
        //             lastSavedContent = content;
        //         }
        //     } catch (error) {
        //         console.error('自动保存失败:', error);
        //     }
        // }

        function openSaveModal() {
            const content = document.getElementById('outline-content').value;
            if (!content.trim()) {
                showToast('请先构建大纲内容', 'error');
                return;
            }
            document.getElementById('save-modal').classList.add('show');
            document.getElementById('title-suggestions-container').style.display = 'none';
            document.getElementById('description-suggestions-container').style.display = 'none';
        }

        function closeSaveModal() {
            document.getElementById('save-modal').classList.remove('show');
        }

        async function generateTitle() {
            const btn = document.getElementById('ai-generate-title-btn');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 生成中...';

            try {
                const data = await api.postForm('/api/title/suggest/', `outline=${encodeURIComponent(currentOutline)}`);
                
                if (data.success && data.titles) {
                    const container = document.getElementById('title-suggestions-container');
                    const list = document.getElementById('title-suggestions-list');
                    list.innerHTML = data.titles.map((title, i) => `
                        <div class="title-suggestion-item" onclick="selectTitle('${escapeHtml(title).replace(/'/g, "\\'")}')">
                            ${i + 1}. ${escapeHtml(title)}
                        </div>
                    `).join('');
                    container.style.display = 'block';
                } else {
                    showToast(data.message || '生成失败', 'error');
                }
            } catch (error) {
                showToast('网络错误，请重试', 'error');
            }

            btn.disabled = false;
            btn.innerHTML = originalText;
        }

        function selectTitle(title) {
            document.getElementById('project-title').value = title;
            document.getElementById('title-suggestions-container').style.display = 'none';
        }

        async function generateDescription() {
            const btn = document.getElementById('ai-generate-desc-btn');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            try {
                const data = await api.postForm('/api/description/suggest/', `outline=${encodeURIComponent(currentOutline)}`);
                
                if (data.success && data.description) {
                    const container = document.getElementById('description-suggestions-container');
                    const content = document.getElementById('description-suggestion-content');
                    content.innerHTML = '<div class="suggestion-tip"><i class="fas fa-hand-pointer"></i> 点击此区域将简介填入输入框</div>' + escapeHtml(data.description).replace(/\n/g, '<br>');
                    content.onclick = function() {
                        selectDescription(data.description);
                    };
                    container.style.display = 'block';
                } else {
                    showToast(data.message || '生成失败', 'error');
                }
            } catch (error) {
                showToast('网络错误，请重试', 'error');
            }

            btn.disabled = false;
            btn.innerHTML = originalText;
        }

        function selectDescription(description) {
            document.getElementById('project-description').value = description;
            document.getElementById('description-suggestions-container').style.display = 'none';
        }

        async function saveProject() {
            const title = document.getElementById('project-title').value.trim();
            if (!title) {
                showToast('请输入小说名称', 'error');
                return;
            }

            const btn = document.getElementById('confirm-save-btn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 保存中...';

            try {
                const saveData = await api.postForm('/api/projects/save/', `project_id=${currentProjectId || ''}&title=${encodeURIComponent(title)}&description=${encodeURIComponent(document.getElementById('project-description').value)}&outline=${encodeURIComponent(currentOutline)}&messages=${encodeURIComponent(JSON.stringify(messages))}`);

                if (saveData.success) {
                    closeSaveModal();
                    showToast('项目保存成功', 'success');
                    setTimeout(() => {
                        window.location.href = `/${saveData.project_id}/`;
                    }, 1500);
                } else {
                    showToast(saveData.message || '保存失败', 'error');
                }
            } catch (error) {
                showToast('网络错误，请重试', 'error');
            }

            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-check me-1"></i> 确认保存';
        }

        function showToast(message, type) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast-item toast-${type}`;
            toast.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i>${message}`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.animation = 'toastSlideOut 0.3s ease forwards';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function goBack() {
            window.location.href = 'index.html';
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function getCookie(name) {
            let cookieValue = null;
            if (document.cookie && document.cookie !== '') {
                const cookies = document.cookie.split(';');
                for (let i = 0; i < cookies.length; i++) {
                    const cookie = cookies[i].trim();
                    if (cookie.substring(0, name.length + 1) === (name + '=')) {
                        cookieValue = decodeURIComponent(cookie.substring(name.length + 1));
                        break;
                    }
                }
            }
            return cookieValue;
        }
    </script>
</body>
</html>
