# ============================================================
# Novel Agent - 环境配置模板
# 复制此文件为 .env 并根据实际情况修改配置
# cp .env.example .env
# ============================================================
# 注释 # local / docker 表示不同部署模式的推荐值

# ==================== Django ====================
# 生产环境请务必修改为随机字符串
SECRET_KEY=change-this-to-a-random-secret-key

# ==================== MySQL 数据库 ====================
# local: localhost / docker: mysql
MYSQL_DB_HOST=localhost
MYSQL_DB_PORT=3306
MYSQL_DB_DATABASE=novel_agent
MYSQL_DB_USER=root
MYSQL_DB_PASSWORD=your_password_here
# Docker 容器初始化密码（仅 docker 部署需要, 本地可忽略, 留空或注释掉）
# MYSQL_ROOT_PASSWORD=your_root_password_here

# ==================== Redis 缓存 ====================
# local: localhost / docker: redis
REDIS_DB_HOST=localhost
REDIS_DB_PORT=6379
REDIS_DB_PASSWORD=
REDIS_DB_DB=0

# ==================== LLM API ====================
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=600
LLM_OUTLINE_TIMEOUT=300
LLM_RETRY=3
LLM_RETRY_INTERVAL=5

# ==================== Embedding 向量化 ====================
# deepseek: 调用 DeepSeek Embedding API（零部署，复用已有 LLM Key）
# local:    本地 sentence-transformers 模型, 或独立 Embedding 服务
# 本地开发推荐: deepseek / docker 部署推荐: local
EMBEDDING_PROVIDER=deepseek
# DeepSeek Embedding 模型（EMBEDDING_PROVIDER=deepseek 时使用）
EMBEDDING_MODEL=deepseek-embedding
# 向量维度（deepseek: 1024, bge-large-zh: 1024）
EMBEDDING_DIM=1024
# 本地模型（EMBEDDING_PROVIDER=local 且未配置 LOCAL_EMBEDDING_URL 时使用）
LOCAL_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
LOCAL_EMBEDDING_DEVICE=cpu
# 独立 Embedding 服务地址（docker-compose 自动部署, 本地可忽略）
# local: 留空 / docker: http://embedding:8000/embed
LOCAL_EMBEDDING_URL=

# ==================== Milvus 向量库 ====================
# local: 使用 pymilvus 嵌入式, 数据存本地文件
# docker: 连接独立 Milvus Standalone 服务
# local: local / docker: docker
MILVUS_MODE=local
# Milvus 服务地址（MILVUS_MODE=docker 时使用）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=novel_knowledge
# 本地文件路径（MILVUS_MODE=local 时使用, 默认项目根目录）
# MILVUS_LOCAL_DB=milvus_demo.db
