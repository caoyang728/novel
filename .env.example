# ============================================================
# Novel Agent - 环境配置模板
# 复制此文件为 .env 并根据实际情况修改配置
# cp .env.example .env
# ============================================================

# ==================== Django 配置 ====================
# Django 密钥（生产环境请务必修改为随机字符串）
DJANGO_SECRET_KEY=django-insecure-@k13^z+7z7z7z7z7z7z7z7z7z7z7z7z7z7z7z7z7z7
# 调试模式（生产环境请设为 False）
# DJANGO_DEBUG=True
# 允许的主机（逗号分隔）
# DJANGO_ALLOWED_HOSTS=*

# ==================== MySQL 数据库配置 ====================
MYSQL_DB_DATABASE=novel_agent
MYSQL_DB_USER=root
MYSQL_DB_PASSWORD=your_password_here
MYSQL_DB_HOST=localhost
MYSQL_DB_PORT=3306

# ==================== Redis 缓存配置 ====================
REDIS_DB_PASSWORD=
REDIS_DB_HOST=localhost
REDIS_DB_PORT=6379
REDIS_DB_DB=0

# ==================== LLM API 配置 ====================
# API 密钥（必填）
LLM_API_KEY=your_api_key_here
# 模型名称
LLM_MODEL=deepseek-chat
# API 地址（默认 DeepSeek，可替换为 OpenAI / 通义千问 / Ollama 等）
LLM_BASE_URL=https://api.deepseek.com
# 生成温度（0.0~1.0，越高越有创造性）
LLM_TEMPERATURE=0.7
# 最大 Token 数
LLM_MAX_TOKENS=4096
# 请求超时时间（秒）
LLM_TIMEOUT=600
# 大纲构建专用超时（秒）
LLM_OUTLINE_TIMEOUT=300
# 请求失败重试次数
LLM_RETRY=3
# 重试间隔（秒）
LLM_RETRY_INTERVAL=5
