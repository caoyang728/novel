# ============================================================
# Novel Agent - 环境配置模板
# 复制此文件为 .env 并根据实际情况修改配置
# cp .env.example .env
# ============================================================

# ==================== Django ====================
# 生产环境请务必修改为随机字符串
SECRET_KEY=change-this-to-a-random-secret-key

# ==================== MySQL 数据库 ====================
# local: localhost / docker: mysql
MYSQL_DB_HOST=localhost
MYSQL_DB_PORT=3306
MYSQL_DB_DATABASE=novel_agent
MYSQL_DB_USER=root
MYSQL_DB_PASSWORD=your_password_here

# ==================== Redis 缓存 ====================
# docker-compose 部署时使用服务名 "redis"，本地开发使用 localhost
REDIS_DB_HOST=localhost
REDIS_DB_PORT=6379
REDIS_DB_PASSWORD=
REDIS_DB_DB=0

# ==================== Embedding 向量化 ====================
# 优先连接 Docker Embedding 服务，不可用则 fallback 到 DeepSeek API
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://api.deepseek.com
EMBEDDING_MODEL=deepseek-v4-flash
EMBEDDING_DIM=1024
# Docker Embedding 服务地址（docker-compose 内部: http://embedding:8000/embed）
EMBEDDING_DOCKER_URL=http://localhost:8080/embed
EMBEDDING_DOCKER_TIMEOUT=30

# ==================== Milvus 向量库 ====================
# docker: 连接独立 Milvus Standalone 服务（primary）
# local:  使用 pymilvus 嵌入式（fallback）
MILVUS_MODE=docker
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=novel_knowledge
MILVUS_LOCAL_DB=milvus_demo.db

# ==================== HuggingFace 镜像源 ====================
HF_ENDPOINT=https://hf-mirror.com
